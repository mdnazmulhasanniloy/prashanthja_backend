    {
      "name": "Messages",
      "description": "Message endpoints for sending, viewing, and managing messages within chats. Note: These routes may need to be registered in the main router.",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "value": "{\n  \"chat\": \"chat_id_here\",\n  \"text\": \"Hello, how are you?\",\n  \"receiver\": \"receiver_user_id\",\n  \"seen\": false\n}",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Message image attachment (optional)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/messages/send-messages",
              "host": ["{{base_url}}"],
              "path": ["messages", "send-messages"]
            },
            "description": "Send a new message in a chat. Requires: user, admin roles."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "    pm.collectionVariables.set('message_id', res.data._id);",
                  "}"
                ],
